# Copy this file to .env and fill in real values before running the backend.

# --- General ---
FRONTEND_URL=http://localhost:5173
ENVIRONMENT=development
# Random secret used to sign auth tokens — generate your own with:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-random-secret
# Comma-separated emails auto-granted admin access (/admin user list)
ADMIN_EMAILS=olalekanquadri58@gmail.com

# --- Email (Gmail SMTP) ---
# Use a Gmail App Password (not your normal Gmail password).
# Generate one at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_APP_PASSWORD=your-gmail-app-password
EMAIL_FROM_NAME=Global Digital Skills Assessment

# --- Payments (deactivated platform-wide for now) ---
PAYMENTS_ENABLED=false

# --- Stripe (test mode keys — replace with live keys at launch) ---
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_USD_CENTS=100

# --- Paystack (test mode keys — replace with live keys at launch) ---
PAYSTACK_SECRET_KEY=sk_test_replace_me
PAYSTACK_PUBLIC_KEY=pk_test_replace_me
PAYSTACK_AMOUNT_KOBO=150000

# --- Consultation booking link (Calendly / Cal.com) ---
CONSULTATION_BOOKING_URL=https://calendly.com/your-handle/consultation

# --- Portfolio link shown in footer/emails ---
PORTFOLIO_URL=https://quaddev.onrender.com/

# --- Database ---
# Defaults to local SQLite if unset. In production, point this at a Postgres
# instance instead (e.g. Render's "Internal Database URL" from your Postgres
# service — only reachable from other Render services, not from your machine):
# DATABASE_URL=postgresql://user:password@host/dbname

